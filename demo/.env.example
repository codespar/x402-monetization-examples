# A CodeSpar test key. This demo refuses anything that is not csk_test_.
# Get one at https://codespar.dev
CODESPAR_API_KEY=csk_test_...

# A Base Sepolia wallet with a little test USDC. The payer is gasless (a relayer
# pays the gas), so it needs USDC but not ETH. Fund it from a Base Sepolia USDC
# faucet, e.g. https://faucet.circle.com
PRIVATE_KEY=0x...

# Optional. Where the $0.01 goes. Defaults to the payer address, so the demo is
# a self-contained loop; set a different address to watch funds move.
# PAYTO_ADDRESS=0x...

# Optional. The API the paywall fronts. Defaults to a public quote endpoint.
# UPSTREAM_URL=https://api.github.com/zen

# Optional. Defaults to https://api.codespar.dev
# CODESPAR_API_BASE=https://api.codespar.dev
